# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored - it never leaves your machine.

# Optional: real web search via Tavily (Job Scout tool).
# Get a key at https://app.tavily.com  (free tier: 1000 credits/month)
# ORCHESTRA_TAVILY_API_KEY=your-key-here

# Optional: override the default local models.
# ORCHESTRA_MAIN_MODEL=qwen2.5:7b
# ORCHESTRA_FAST_MODEL=qwen2.5:7b
